{
	"name": "@loreweave/types",
	"version": "0.1.0",
	"private": true,
	"description": "Shared type definitions for LoreWeave",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"files": [
		"dist"
	]
}
