{
	"name": "@loreweave/agents",
	"version": "0.1.0",
	"private": true,
	"description": "Agent adapters for LLM-driven code generation — supports coding agents (Claude CLI) and direct LLM APIs",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"test": "vitest run --passWithNoTests",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"vitest": "^3.1.1"
	},
	"files": [
		"dist"
	]
}
