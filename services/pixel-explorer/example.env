# Pixel Explorer Environment Configuration
# Copy this file to .env in your working directory:
#   cp example.env .env

# Required for asset generation via Agent SDK
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model to use for generation (optional — defaults to SDK default)
# Examples:
#   claude-sonnet-4-5-20250929   — Fast, good for simple sprites
#   claude-sonnet-4-6-20250514   — Latest Sonnet, balanced speed/quality
#   claude-haiku-4-5-20251001    — Fastest, cheapest, good for iteration
#   claude-opus-4-6-20250514     — Most capable, best for complex scenes
# CLAUDE_MODEL=claude-sonnet-4-6-20250514
