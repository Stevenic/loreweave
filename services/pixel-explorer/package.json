{
	"name": "@loreweave/pixel-explorer",
	"version": "0.2.0",
	"private": true,
	"description": "Web-based pixel asset generator and explorer for Pixel Format v1",
	"type": "module",
	"main": "./dist/index.js",
	"bin": {
		"pixel-explorer": "./dist/index.js"
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"start": "node dist/index.js start",
		"test": "vitest run --passWithNoTests",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@loreweave/agents": "*",
		"@loreweave/pixel": "*",
		"@loreweave/types": "*",
		"ws": "^8.18.0"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"@types/ws": "^8.18.0",
		"vitest": "^3.1.1"
	}
}
